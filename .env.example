# MealMate Lite — Docker Compose 环境变量
# 复制为 .env 并填入实际值

# PostgreSQL
DB_NAME=mealmate
DB_USER=mealmate
MEALMATE_DB_PASSWORD_FILE=/path/to/db-password-file

# App
MEALMATE_BOOTSTRAP_SECRET=          # 至少 256 位随机值（64 位十六进制或 43 位 base64url）
MEALMATE_MODELS_FILE=/path/to/models.json
MEALMATE_PUBLIC_DOMAIN=your-domain.example.com
